{
  "name": "noteswap",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "setup": "npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}